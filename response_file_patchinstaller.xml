<project>

	<!-- 
		PATCHES DIR
		===========
		
		INDICATES THE DIRECTORY WHERE PATCHES TO BE INSTALLED
		ARE TO BE FOUND.
		
		 1. value - a path to a directory
		 e.g /tmp/patches, C:\temp\patches
	-->
	
	<property name="patches.dir" value="/tmp/patches" />
	
	<!-- 
		USE FILTER FILES ?
		==================

		INDICATES WHETHER OR NOT FILTER FILES LOCATED IN THE PATCH DIRECTORY
		SHOULD BE CONSIDERED WHEN THE PATCH INSTALLER DETERMINES	WHICH PATCHES TO
		INSTALL. 
		
		THE PATCH INSTALLER CONSIDERS ANY FILE WITH THE EXTENSION ".FILTER" TO BE
		A FILTER FILE. A FILTER FILE IS A TEXT FILE WHERE EACH LINE IS ASSUMED TO
		BE THE NAME OF A PATCH FILE NAME, EXCLUDING THEIR EXTENSIONS (.EXE/.ZIP/.TAR.GZ),
		THAT SHOULD BE CONSIDERED FOR INSTALLATION, IF THE PATCH FILE WITH THAT NAME
		IS PRESENT IN THE SPECIFIED PATCH DIRECTORY.
		
		EXAMPLE:
		
		CONSIDER A FILTER FILE WITH THE FOLLOWING CONTENTS:

			RealtimeFramework_v5.4_patch003_build416295
			RealtimeFramework_v5.4_patch017_build435132
			PostCard_v5.4_patch008_build457550
		
		ONLY PATCH FILES WITH NAMES MATCHING THE ABOVE WILL BE CONSIDERED FOR INSTALLATION.
		
		ONLY PATCHES THAT ARE LISTED IN ANY FILTER FILE WILL BE CONSIDERED FOR 
		INSTALLATION. IF A PATCH FILE IS PRESENT IN THE PATCH DIRECTORY BUT NOT LISTED
		IN ONE OF THE FILTER FILES THEN IT WILL NOT BE CONSIDERED FOR INSTALLATION.
		
		EMPTY FILTER FILES ARE IGNORED.

		 1. value - "true" or "false"
	-->
		
	<property name="use.filter.files" value="true" />
	
	<!-- 
		PATCH PREVIEW ?
		===============
		
		INDICATES WHETHER ONLY A LIST OF APPLICABLE PATCHES SHOULD BE GENERATED FOR REVIEW.
		THIS SHOULD BE SET TO "true" IF YOU WANT TO GENERATE A LIST OF PATCHES THAT WOULD BE
		INSTALLED, BUT NOT ACTUALLY INSTALL THEM.
		
		 1. value - "true" or "false"
	-->
	
	<property name="patches.preview" value="false" />
	
</project>

